# tdengine/tdgpt-env-amd64:1.1
ARG ARCH=amd64
ARG PIP_INDEX_URL=
ARG PYTHON_BASE=python:3.10-slim-trixie
ARG TORCH_INDEX=https://download.pytorch.org/whl/cpu

FROM ${PYTHON_BASE} AS base-builder
ARG ARCH=amd64
ARG PIP_INDEX_URL
ARG TORCH_INDEX
COPY ./requirements_docker.txt /tmp/requirements_docker.txt
RUN apt-get -o Acquire::Check-Valid-Until=false -o Acquire::Check-Date=false update -y && \
    apt-get install -y --no-install-recommends gcc libc-dev procps && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Use CPU-only torch/tensorflow in this image (no CUDA dependency)
# Install torch/tensorflow first, then install requirements to avoid dependency override/conflicts
RUN if [ "$ARCH" = "arm64" ]; then \
        TORCH_PKG="torch"; \
        TENSORFLOW_PKG="tensorflow"; \
    else \
        TORCH_PKG="torch==2.3.1+cpu"; \
        TENSORFLOW_PKG="tensorflow-cpu==2.15.0"; \
    fi && \
    PIP_INDEX_ARG="${PIP_INDEX_URL:+-i ${PIP_INDEX_URL}}" && \
    pip3 install --upgrade pip && \
    pip3 install --no-cache-dir $TORCH_PKG --index-url $TORCH_INDEX && \
    pip3 install --no-cache-dir \
                -r /tmp/requirements_docker.txt \
                ${PIP_INDEX_ARG} && \
    pip3 install --no-cache-dir accelerate==0.34.2 ${PIP_INDEX_ARG} && \
    find /usr/local/lib/python3.10 -type d \( -name '__pycache__' -o -name 'tests' \) -exec rm -rf {} + 2>/dev/null

FROM ${PYTHON_BASE} AS venv1-builder
ARG PIP_INDEX_URL
COPY --from=base-builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=base-builder /usr/local/bin /usr/local/bin
ENV VIRTUAL_ENV=/var/lib/taos/taosanode/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
RUN python3.10 -m venv --system-site-packages $VIRTUAL_ENV && \
    PIP_INDEX_ARG="${PIP_INDEX_URL:+-i ${PIP_INDEX_URL}}" && \
    pip3 install --no-cache-dir transformers==4.40 ${PIP_INDEX_ARG} && \
    find $VIRTUAL_ENV -type d \( -name '__pycache__' -o -name 'tests' \) -exec rm -rf {} + 2>/dev/null

FROM ${PYTHON_BASE} AS venv2-builder
ARG PIP_INDEX_URL
COPY --from=base-builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=base-builder /usr/local/bin /usr/local/bin
ENV VIRTUAL_ENV=/var/lib/taos/taosanode/venv_chronos
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
RUN python3.10 -m venv --system-site-packages $VIRTUAL_ENV && \
    PIP_INDEX_ARG="${PIP_INDEX_URL:+-i ${PIP_INDEX_URL}}" && \
    pip3 install --no-cache-dir transformers==4.55 chronos-forecasting ${PIP_INDEX_ARG} && \
    find $VIRTUAL_ENV -type d \( -name '__pycache__' -o -name 'tests' \) -exec rm -rf {} + 2>/dev/null

FROM ${PYTHON_BASE} AS venv3-builder
ARG PIP_INDEX_URL
COPY --from=base-builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=base-builder /usr/local/bin /usr/local/bin
ENV VIRTUAL_ENV=/var/lib/taos/taosanode/venv_timesfm
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
RUN python3.10 -m venv --system-site-packages $VIRTUAL_ENV && \
    PIP_INDEX_ARG="${PIP_INDEX_URL:+-i ${PIP_INDEX_URL}}" && \
    pip3 install --no-cache-dir transformers==4.33.3 momentfm ${PIP_INDEX_ARG} && \
    find $VIRTUAL_ENV -type d \( -name '__pycache__' -o -name 'tests' \) -exec rm -rf {} + 2>/dev/null


FROM ${PYTHON_BASE} AS venv4-builder
ARG ARCH=amd64
ARG PIP_INDEX_URL
ARG TORCH_INDEX
COPY --from=base-builder /usr/local/bin /usr/local/bin
ENV VIRTUAL_ENV=/var/lib/taos/taosanode/venv_moirai
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
RUN python3.10 -m venv --system-site-packages $VIRTUAL_ENV && \
    PIP_INDEX_ARG="${PIP_INDEX_URL:+-i ${PIP_INDEX_URL}}" && \
    if [ "$ARCH" = "arm64" ]; then \
        TORCH_PKG="torch"; \
    else \
        TORCH_PKG="torch==2.3.1+cpu"; \
    fi && \
    pip3 install --no-cache-dir $TORCH_PKG --index-url $TORCH_INDEX && \
    pip3 install --no-cache-dir uni2ts flask ${PIP_INDEX_ARG} && \
    find $VIRTUAL_ENV -type d \( -name '__pycache__' -o -name 'tests' \) -exec rm -rf {} + 2>/dev/null

FROM ${PYTHON_BASE}
RUN apt-get update -y && \
    apt-get install -y --no-install-recommends gcc libc-dev g++ build-essential procps && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
COPY --from=base-builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=base-builder /usr/local/bin /usr/local/bin
COPY --from=venv1-builder /var/lib/taos/taosanode/venv /var/lib/taos/taosanode/venv
COPY --from=venv2-builder /var/lib/taos/taosanode/venv_chronos /var/lib/taos/taosanode/venv_chronos
COPY --from=venv3-builder /var/lib/taos/taosanode/venv_timesfm /var/lib/taos/taosanode/venv_timesfm
COPY --from=venv4-builder /var/lib/taos/taosanode/venv_moirai /var/lib/taos/taosanode/venv_moirai
