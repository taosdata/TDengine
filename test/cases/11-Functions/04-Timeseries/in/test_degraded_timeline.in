## ========================================
## Section HF: Degraded window functions
## ========================================
## HF1a - INTERVAL 退化正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) INTERVAL(2s);
## HF1b - SESSION 退化正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) SESSION(event_time, 1s);
## HF1c - STATE_WINDOW 退化正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) STATE_WINDOW(st);
## HF1d - EVENT_WINDOW 退化正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## HF1e - COUNT_WINDOW 退化正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) COUNT_WINDOW(2);

