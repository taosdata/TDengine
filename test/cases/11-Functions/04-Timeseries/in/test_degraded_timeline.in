CREATE TABLE t_event_fill_rand (ts TIMESTAMP, event_time TIMESTAMP, val INT);
INSERT INTO t_event_fill_rand VALUES ('2024-01-01 00:00:01', '2024-06-01 00:00:03', NULL) ('2024-01-01 00:00:02', '2024-06-01 00:00:01', 10) ('2024-01-01 00:00:03', '2024-06-01 00:00:05', NULL) ('2024-01-01 00:00:04', '2024-06-01 00:00:02', 40) ('2024-01-01 00:00:05', '2024-06-01 00:00:04', NULL);
CREATE TABLE t_event_fill_dup (ts TIMESTAMP, event_time TIMESTAMP, val INT);
INSERT INTO t_event_fill_dup VALUES ('2024-01-01 00:00:01', '2024-06-01 00:00:01', 10) ('2024-01-01 00:00:02', '2024-06-01 00:00:02', NULL) ('2024-01-01 00:00:03', '2024-06-01 00:00:02', NULL) ('2024-01-01 00:00:04', '2024-06-01 00:00:03', 40) ('2024-01-01 00:00:05', '2024-06-01 00:00:04', NULL);
CREATE TABLE t_event_fill_null1 (ts TIMESTAMP, event_time TIMESTAMP, val INT);
INSERT INTO t_event_fill_null1 VALUES ('2024-01-01 00:00:01', NULL, 10) ('2024-01-01 00:00:02', '2024-06-01 00:00:02', NULL) ('2024-01-01 00:00:03', '2024-06-01 00:00:03', NULL) ('2024-01-01 00:00:04', '2024-06-01 00:00:04', 40) ('2024-01-01 00:00:05', '2024-06-01 00:00:05', NULL);
CREATE TABLE t_event_fill_nulls (ts TIMESTAMP, event_time TIMESTAMP, val INT);
INSERT INTO t_event_fill_nulls VALUES ('2024-01-01 00:00:01', NULL, 10) ('2024-01-01 00:00:02', NULL, NULL) ('2024-01-01 00:00:03', '2024-06-01 00:00:03', NULL) ('2024-01-01 00:00:04', '2024-06-01 00:00:04', 40) ('2024-01-01 00:00:05', '2024-06-01 00:00:05', NULL);

