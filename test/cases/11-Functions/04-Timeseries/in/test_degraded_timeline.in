SELECT last_row(val) FROM (SELECT * FROM t_base ORDER BY t2);
## JA5d - tail ORDER BY t2
SELECT tail(val, 2) FROM (SELECT * FROM t_base ORDER BY t2);
## JA5e - unique ORDER BY t2
SELECT unique(val) FROM (SELECT * FROM t_base ORDER BY t2);

