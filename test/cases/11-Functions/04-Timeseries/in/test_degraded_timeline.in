## ========================================
## Section HF-EXT: Degraded EXTERNAL_WINDOW
## ========================================
## HF-EXT setup: boundary table for degraded ts range
CREATE TABLE t_ext_bounds2 (ts TIMESTAMP, endtime TIMESTAMP);
INSERT INTO t_ext_bounds2 VALUES ('2024-06-01 00:00:01', '2024-06-01 00:00:02') ('2024-06-01 00:00:03', '2024-06-01 00:00:05');

## HF7a - EXTERNAL_WINDOW 退化正序
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);
## HF7b - EXTERNAL_WINDOW 退化倒序
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event_desc) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);
## HF7c - EXTERNAL_WINDOW 退化乱序
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event_rand) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);
## HF7d - EXTERNAL_WINDOW 退化重复ts
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event_dup) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);
## HF7e - EXTERNAL_WINDOW 退化NULL(1)
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event_null) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);
## HF7f - EXTERNAL_WINDOW 退化NULL(2+)
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event_nulls) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);

