USE test_pk_matrix;
## ========================================
## Section A: Selection functions (PK)
## ========================================
## A1a - last 正序
SELECT last(val) FROM t_base;
## A1b - first 正序
SELECT first(val) FROM t_base;
## A1c - last_row 正序
SELECT last_row(val) FROM t_base;
## A1d - tail 正序
SELECT tail(val, 2) FROM t_base;
## A1e - unique 正序
SELECT unique(val) FROM t_base;

## A2a - last 倒序
SELECT last(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2b - first 倒序
SELECT first(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2c - last_row 倒序
SELECT last_row(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2d - tail 倒序
SELECT tail(val, 2) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2e - unique 倒序
SELECT unique(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## A4a - last 重复ts
SELECT last(val) FROM t_dup;
## A4b - first 重复ts
SELECT first(val) FROM t_dup;
## A4c - last_row 重复ts
SELECT last_row(val) FROM t_dup;
## A4d - tail 重复ts
SELECT tail(val, 2) FROM t_dup;
## A4e - unique 重复ts
SELECT unique(val) FROM t_dup;

## ========================================
## Section B: elapsed (PK)
## ========================================
## B1 - elapsed 正序
SELECT elapsed(ts, 1s) FROM t_base;
## B2 - elapsed 倒序
SELECT elapsed(ts, 1s) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## B4 - elapsed 重复ts
SELECT elapsed(ts, 1s) FROM t_dup;

## ========================================
## Section C: derivative, twa, irate (PK)
## ========================================
## C1a - derivative 正序
SELECT derivative(val, 1s, 0) FROM t_base;
## C1b - twa 正序
SELECT twa(val) FROM t_base;
## C1c - irate 正序
SELECT irate(val) FROM t_base;

## C2a - derivative 倒序
SELECT derivative(val, 1s, 0) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## C2b - twa 倒序
SELECT twa(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## C2c - irate 倒序
SELECT irate(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## C4a - derivative 重复ts
SELECT derivative(val, 1s, 0) FROM t_dup;
## C4b - twa 重复ts
SELECT twa(val) FROM t_dup;
## C4c - irate 重复ts
SELECT irate(val) FROM t_dup;

## ========================================
## Section D: diff, csum, mavg, statecount, stateduration (PK)
## ========================================
## D1a - diff 正序
SELECT diff(val) FROM t_base;
## D1b - csum 正序
SELECT csum(val) FROM t_base;
## D1c - mavg 正序
SELECT mavg(val, 2) FROM t_base;
## D1d - statecount 正序
SELECT statecount(val, 'GE', 30) FROM t_base;
## D1e - stateduration 正序
SELECT stateduration(val, 'GE', 30, 1s) FROM t_base;

## D2a - diff 倒序
SELECT diff(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2b - csum 倒序
SELECT csum(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2c - mavg 倒序
SELECT mavg(val, 2) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2d - statecount 倒序
SELECT statecount(val, 'GE', 30) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2e - stateduration 倒序
SELECT stateduration(val, 'GE', 30, 1s) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## D4a - diff 重复ts
SELECT diff(val) FROM t_dup;
## D4b - csum 重复ts (expect: error dup ts)
SELECT csum(val) FROM t_dup;
## D4c - mavg 重复ts (expect: error dup ts)
SELECT mavg(val, 2) FROM t_dup;
## D4d - statecount 重复ts (expect: error dup ts)
SELECT statecount(val, 'GE', 30) FROM t_dup;
## D4e - stateduration 重复ts (expect: error dup ts)
SELECT stateduration(val, 'GE', 30, 1s) FROM t_dup;

## ========================================
## Section E: lag, lead, fill_forward (PK)
## ========================================
## E1a - lag 正序
SELECT lag(val, 1) FROM t_base;
## E1b - lead 正序
SELECT lead(val, 1) FROM t_base;
## E1c - fill_forward 正序
SELECT fill_forward(val) FROM t_fill;

## E2a - lag 倒序
SELECT lag(val, 1) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## E2b - lead 倒序
SELECT lead(val, 1) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## E2c - fill_forward 倒序
SELECT fill_forward(val) FROM (SELECT * FROM t_fill ORDER BY ts DESC);

## E4a - lag 重复ts
SELECT lag(val, 1) FROM t_dup;
## E4b - lead 重复ts
SELECT lead(val, 1) FROM t_dup;
## E4c - fill_forward 重复ts
SELECT fill_forward(val) FROM t_fill_dup;

## ========================================
## Section F: Window functions (PK)
## ========================================
## F1a - INTERVAL 正序
SELECT count(*) FROM t_base INTERVAL(2s);
## F1b - SESSION 正序
SELECT count(*) FROM t_base SESSION(ts, 1s);
## F1c - STATE_WINDOW 正序
SELECT count(*) FROM t_base STATE_WINDOW(st);
## F1d - EVENT_WINDOW 正序
SELECT count(*) FROM t_base EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F1e - COUNT_WINDOW 正序
SELECT count(*) FROM t_base COUNT_WINDOW(2);

## F2a - INTERVAL 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) INTERVAL(2s);
## F2b - SESSION 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) SESSION(ts, 1s);
## F2c - STATE_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) STATE_WINDOW(st);
## F2d - EVENT_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F2e - COUNT_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) COUNT_WINDOW(2);

## F4a - INTERVAL 重复ts
SELECT count(*) FROM t_dup INTERVAL(2s);
## F4b - SESSION 重复ts
SELECT count(*) FROM t_dup SESSION(ts, 1s);
## F4c - STATE_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup STATE_WINDOW(st);
## F4d - EVENT_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup EVENT_WINDOW START WITH val >= 20 END WITH val >= 30;
## F4e - COUNT_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup COUNT_WINDOW(2);

## F5a - EXTERNAL_WINDOW 正序
SELECT _wstart, _wend, count(*) FROM t_base external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5b - EXTERNAL_WINDOW 倒序
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5d - EXTERNAL_WINDOW 重复ts
SELECT _wstart, _wend, count(*) FROM t_dup external_window((SELECT ts, endtime FROM t_ext_bounds) w);

## ========================================
## Section G: interp (PK)
## ========================================
## G1 - interp 正序
SELECT interp(val) FROM t_base RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G2 - interp 倒序
SELECT interp(val) FROM (SELECT * FROM t_base ORDER BY ts DESC) RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G4 - interp 重复ts
SELECT interp(val) FROM t_dup RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:03') EVERY(1s) FILL(LINEAR);
