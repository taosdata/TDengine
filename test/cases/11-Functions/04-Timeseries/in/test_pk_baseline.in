USE test_pk_matrix;
## ========================================
## Section A: Selection functions (PK)
## ========================================
## A1a - last 正序
SELECT last(val) FROM t_base;
## A1b - first 正序
SELECT first(val) FROM t_base;
## A1c - last_row 正序
SELECT last_row(val) FROM t_base;
## A1d - tail 正序
SELECT tail(val, 2) FROM t_base;
## A1e - unique 正序
SELECT unique(val) FROM t_base;

## A2a - last 倒序
SELECT last(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2b - first 倒序
SELECT first(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2c - last_row 倒序
SELECT last_row(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2d - tail 倒序
SELECT tail(val, 2) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## A2e - unique 倒序
SELECT unique(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## A3a - last 乱序 (ORDER BY val, ts still present but disordered)
SELECT last(val) FROM (SELECT * FROM t_base ORDER BY val);
## A3b - first 乱序
SELECT first(val) FROM (SELECT * FROM t_base ORDER BY val);
## A3c - last_row 乱序
SELECT last_row(val) FROM (SELECT * FROM t_base ORDER BY val);
## A3d - tail 乱序
SELECT tail(val, 2) FROM (SELECT * FROM t_base ORDER BY val);
## A3e - unique 乱序
SELECT unique(val) FROM (SELECT * FROM t_base ORDER BY val);

## A5a - last ORDER BY t2
SELECT last(val) FROM (SELECT * FROM t_base ORDER BY t2);
## A5b - first ORDER BY t2
SELECT first(val) FROM (SELECT * FROM t_base ORDER BY t2);
## A5c - last_row ORDER BY t2
SELECT last_row(val) FROM (SELECT * FROM t_base ORDER BY t2);
## A5d - tail ORDER BY t2
SELECT tail(val, 2) FROM (SELECT * FROM t_base ORDER BY t2);
## A5e - unique ORDER BY t2
SELECT unique(val) FROM (SELECT * FROM t_base ORDER BY t2);

## A4a - last 重复ts
SELECT last(val) FROM t_dup;
## A4b - first 重复ts
SELECT first(val) FROM t_dup;
## A4c - last_row 重复ts
SELECT last_row(val) FROM t_dup;
## A4d - tail 重复ts
SELECT tail(val, 2) FROM t_dup;
## A4e - unique 重复ts
SELECT unique(val) FROM t_dup;

## A6a - last 无主键 (subquery strips ts, expect: error on 3.0)
SELECT last(val) FROM (SELECT event_time, val, st FROM t_event);
## A6b - first 无主键
SELECT first(val) FROM (SELECT event_time, val, st FROM t_event);
## A6c - last_row 无主键
SELECT last_row(val) FROM (SELECT event_time, val, st FROM t_event);
## A6d - tail 无主键
SELECT tail(val, 2) FROM (SELECT event_time, val, st FROM t_event);
## A6e - unique 无主键
SELECT unique(val) FROM (SELECT event_time, val, st FROM t_event);

## ========================================
## Section B: elapsed (PK)
## ========================================
## B1 - elapsed 正序
SELECT elapsed(ts, 1s) FROM t_base;
## B2 - elapsed 倒序
SELECT elapsed(ts, 1s) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## B3 - elapsed 乱序 (ORDER BY val, expect: error)
SELECT elapsed(ts, 1s) FROM (SELECT * FROM t_base ORDER BY val);
## B5 - elapsed ORDER BY t2 (expect: error)
SELECT elapsed(ts, 1s) FROM (SELECT * FROM t_base ORDER BY t2);
## B4 - elapsed 重复ts
SELECT elapsed(ts, 1s) FROM t_dup;
## B6 - elapsed 无主键 (expect: error)
SELECT elapsed(event_time, 1s) FROM (SELECT event_time, val FROM t_event);

## ========================================
## Section C: derivative, twa, irate (PK)
## ========================================
## C1a - derivative 正序
SELECT derivative(val, 1s, 0) FROM t_base;
## C1b - twa 正序
SELECT twa(val) FROM t_base;
## C1c - irate 正序
SELECT irate(val) FROM t_base;

## C2a - derivative 倒序
SELECT derivative(val, 1s, 0) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## C2b - twa 倒序
SELECT twa(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## C2c - irate 倒序
SELECT irate(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## C3a - derivative 乱序 (expect: error)
SELECT derivative(val, 1s, 0) FROM (SELECT * FROM t_base ORDER BY val);
## C3b - twa 乱序 (expect: error)
SELECT twa(val) FROM (SELECT * FROM t_base ORDER BY val);
## C3c - irate 乱序 (expect: error)
SELECT irate(val) FROM (SELECT * FROM t_base ORDER BY val);

## C5a - derivative ORDER BY t2 (expect: error)
SELECT derivative(val, 1s, 0) FROM (SELECT * FROM t_base ORDER BY t2);
## C5b - twa ORDER BY t2 (expect: error)
SELECT twa(val) FROM (SELECT * FROM t_base ORDER BY t2);
## C5c - irate ORDER BY t2 (expect: error)
SELECT irate(val) FROM (SELECT * FROM t_base ORDER BY t2);

## C4a - derivative 重复ts
SELECT derivative(val, 1s, 0) FROM t_dup;
## C4b - twa 重复ts
SELECT twa(val) FROM t_dup;
## C4c - irate 重复ts
SELECT irate(val) FROM t_dup;

## C6a - derivative 无主键 (expect: error)
SELECT derivative(val, 1s, 0) FROM (SELECT event_time, val FROM t_event);
## C6b - twa 无主键 (expect: error)
SELECT twa(val) FROM (SELECT event_time, val FROM t_event);
## C6c - irate 无主键 (expect: error)
SELECT irate(val) FROM (SELECT event_time, val FROM t_event);

## ========================================
## Section D: diff, csum, mavg, statecount, stateduration (PK)
## ========================================
## D1a - diff 正序
SELECT diff(val) FROM t_base;
## D1b - csum 正序
SELECT csum(val) FROM t_base;
## D1c - mavg 正序
SELECT mavg(val, 2) FROM t_base;
## D1d - statecount 正序
SELECT statecount(val, 'GE', 30) FROM t_base;
## D1e - stateduration 正序
SELECT stateduration(val, 'GE', 30, 1s) FROM t_base;

## D2a - diff 倒序
SELECT diff(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2b - csum 倒序
SELECT csum(val) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2c - mavg 倒序
SELECT mavg(val, 2) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2d - statecount 倒序
SELECT statecount(val, 'GE', 30) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## D2e - stateduration 倒序
SELECT stateduration(val, 'GE', 30, 1s) FROM (SELECT * FROM t_base ORDER BY ts DESC);

## D3a - diff 乱序 (expect: error)
SELECT diff(val) FROM (SELECT * FROM t_base ORDER BY val);
## D3b - csum 乱序 (expect: error)
SELECT csum(val) FROM (SELECT * FROM t_base ORDER BY val);
## D3c - mavg 乱序 (expect: error)
SELECT mavg(val, 2) FROM (SELECT * FROM t_base ORDER BY val);
## D3d - statecount 乱序 (expect: error)
SELECT statecount(val, 'GE', 30) FROM (SELECT * FROM t_base ORDER BY val);
## D3e - stateduration 乱序 (expect: error)
SELECT stateduration(val, 'GE', 30, 1s) FROM (SELECT * FROM t_base ORDER BY val);

## D5a - diff ORDER BY t2 (expect: error)
SELECT diff(val) FROM (SELECT * FROM t_base ORDER BY t2);
## D5b - csum ORDER BY t2 (expect: error)
SELECT csum(val) FROM (SELECT * FROM t_base ORDER BY t2);
## D5c - mavg ORDER BY t2 (expect: error)
SELECT mavg(val, 2) FROM (SELECT * FROM t_base ORDER BY t2);
## D5d - statecount ORDER BY t2 (expect: error)
SELECT statecount(val, 'GE', 30) FROM (SELECT * FROM t_base ORDER BY t2);
## D5e - stateduration ORDER BY t2 (expect: error)
SELECT stateduration(val, 'GE', 30, 1s) FROM (SELECT * FROM t_base ORDER BY t2);

## D4a - diff 重复ts
SELECT diff(val) FROM t_dup;
## D4b - csum 重复ts (expect: error dup ts)
SELECT csum(val) FROM t_dup;
## D4c - mavg 重复ts (expect: error dup ts)
SELECT mavg(val, 2) FROM t_dup;
## D4d - statecount 重复ts (expect: error dup ts)
SELECT statecount(val, 'GE', 30) FROM t_dup;
## D4e - stateduration 重复ts (expect: error dup ts)
SELECT stateduration(val, 'GE', 30, 1s) FROM t_dup;

## D6a - diff 无主键 (expect: error)
SELECT diff(val) FROM (SELECT event_time, val FROM t_event);
## D6b - csum 无主键 (expect: error)
SELECT csum(val) FROM (SELECT event_time, val FROM t_event);
## D6c - mavg 无主键 (expect: error)
SELECT mavg(val, 2) FROM (SELECT event_time, val FROM t_event);
## D6d - statecount 无主键 (expect: error)
SELECT statecount(val, 'GE', 30) FROM (SELECT event_time, val, st FROM t_event);
## D6e - stateduration 无主键 (expect: error)
SELECT stateduration(val, 'GE', 30, 1s) FROM (SELECT event_time, val, st FROM t_event);

## ========================================
## Section E: lag, lead, fill_forward (PK)
## ========================================
## E1a - lag 正序
SELECT lag(val, 1) FROM t_base;
## E1b - lead 正序
SELECT lead(val, 1) FROM t_base;
## E1c - fill_forward 正序
SELECT fill_forward(val) FROM t_fill;

## E2a - lag 倒序
SELECT lag(val, 1) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## E2b - lead 倒序
SELECT lead(val, 1) FROM (SELECT * FROM t_base ORDER BY ts DESC);
## E2c - fill_forward 倒序
SELECT fill_forward(val) FROM (SELECT * FROM t_fill ORDER BY ts DESC);

## E3a - lag 乱序 (expect: error)
SELECT lag(val, 1) FROM (SELECT * FROM t_base ORDER BY val);
## E3b - lead 乱序 (expect: error)
SELECT lead(val, 1) FROM (SELECT * FROM t_base ORDER BY val);
## E3c - fill_forward 乱序 (expect: error)
SELECT fill_forward(val) FROM (SELECT * FROM t_fill ORDER BY val);

## E5a - lag ORDER BY t2 (expect: error)
SELECT lag(val, 1) FROM (SELECT * FROM t_base ORDER BY t2);
## E5b - lead ORDER BY t2 (expect: error)
SELECT lead(val, 1) FROM (SELECT * FROM t_base ORDER BY t2);
## E5c - fill_forward ORDER BY t2 (expect: error)
SELECT fill_forward(val) FROM (SELECT * FROM t_base ORDER BY t2);

## E4a - lag 重复ts
SELECT lag(val, 1) FROM t_dup;
## E4b - lead 重复ts
SELECT lead(val, 1) FROM t_dup;
## E4c - fill_forward 重复ts
SELECT fill_forward(val) FROM t_fill_dup;

## E6a - lag 无主键 (expect: error)
SELECT lag(val, 1) FROM (SELECT event_time, val FROM t_event);
## E6b - lead 无主键 (expect: error)
SELECT lead(val, 1) FROM (SELECT event_time, val FROM t_event);
## E6c - fill_forward 无主键 (expect: error)
SELECT fill_forward(val) FROM (SELECT event_time, val FROM t_event_fill);

## ========================================
## Section F: Window functions (PK)
## ========================================
## F1a - INTERVAL 正序
SELECT count(*) FROM t_base INTERVAL(2s);
## F1b - SESSION 正序
SELECT count(*) FROM t_base SESSION(ts, 1s);
## F1c - STATE_WINDOW 正序
SELECT count(*) FROM t_base STATE_WINDOW(st);
## F1d - EVENT_WINDOW 正序
SELECT count(*) FROM t_base EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F1e - COUNT_WINDOW 正序
SELECT count(*) FROM t_base COUNT_WINDOW(2);

## F2a - INTERVAL 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) INTERVAL(2s);
## F2b - SESSION 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) SESSION(ts, 1s);
## F2c - STATE_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) STATE_WINDOW(st);
## F2d - EVENT_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F2e - COUNT_WINDOW 倒序
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) COUNT_WINDOW(2);

## F3a - INTERVAL 乱序 (should work - INTERVAL sorts internally)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY val) INTERVAL(2s);
## F3b - SESSION 乱序 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY val) SESSION(ts, 1s);
## F3c - STATE_WINDOW 乱序 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY val) STATE_WINDOW(st);
## F3d - EVENT_WINDOW 乱序 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY val) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F3e - COUNT_WINDOW 乱序 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY val) COUNT_WINDOW(2);
## F3f - EXTERNAL_WINDOW 乱序 (expect: error)
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY val) external_window((SELECT ts, endtime FROM t_ext_bounds) w);

## F6a - INTERVAL ORDER BY t2 (should work)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY t2) INTERVAL(2s);
## F6b - SESSION ORDER BY t2 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY t2) SESSION(ts, 1s);
## F6c - STATE_WINDOW ORDER BY t2 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY t2) STATE_WINDOW(st);
## F6d - EVENT_WINDOW ORDER BY t2 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY t2) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F6e - COUNT_WINDOW ORDER BY t2 (expect: error)
SELECT count(*) FROM (SELECT * FROM t_base ORDER BY t2) COUNT_WINDOW(2);
## F6f - EXTERNAL_WINDOW ORDER BY t2 (expect: error)
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY t2) external_window((SELECT ts, endtime FROM t_ext_bounds) w);

## F4a - INTERVAL 重复ts
SELECT count(*) FROM t_dup INTERVAL(2s);
## F4b - SESSION 重复ts
SELECT count(*) FROM t_dup SESSION(ts, 1s);
## F4c - STATE_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup STATE_WINDOW(st);
## F4d - EVENT_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup EVENT_WINDOW START WITH val >= 20 END WITH val >= 30;
## F4e - COUNT_WINDOW 重复ts (expect: error dup ts)
SELECT count(*) FROM t_dup COUNT_WINDOW(2);

## F5a - EXTERNAL_WINDOW 正序
SELECT _wstart, _wend, count(*) FROM t_base external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5b - EXTERNAL_WINDOW 倒序
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY ts DESC) external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5c - EXTERNAL_WINDOW 乱序 (expect: error)
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY val) external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5e - EXTERNAL_WINDOW ORDER BY t2 (expect: error)
SELECT _wstart, _wend, count(*) FROM (SELECT * FROM t_base ORDER BY t2) external_window((SELECT ts, endtime FROM t_ext_bounds) w);
## F5d - EXTERNAL_WINDOW 重复ts
SELECT _wstart, _wend, count(*) FROM t_dup external_window((SELECT ts, endtime FROM t_ext_bounds) w);

## F7a - INTERVAL 无主键 (expect: error)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) INTERVAL(2s);
## F7b - SESSION 无主键 (expect: error)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) SESSION(event_time, 1s);
## F7c - STATE_WINDOW 无主键 (expect: error)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) STATE_WINDOW(st);
## F7d - EVENT_WINDOW 无主键 (expect: error)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
## F7e - COUNT_WINDOW 无主键 (expect: error)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) COUNT_WINDOW(2);
## F7f - EXTERNAL_WINDOW 无主键 (expect: error)
SELECT _wstart, _wend, count(*) FROM (SELECT event_time, val, st FROM t_event) external_window((SELECT ts, endtime FROM t_ext_bounds2) w);

## ========================================
## Section G: interp (PK)
## ========================================
## G1 - interp 正序
SELECT interp(val) FROM t_base RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G2 - interp 倒序
SELECT interp(val) FROM (SELECT * FROM t_base ORDER BY ts DESC) RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G3 - interp 乱序 (expect: error)
SELECT interp(val) FROM (SELECT * FROM t_base ORDER BY val) RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G5 - interp ORDER BY t2 (expect: error)
SELECT interp(val) FROM (SELECT * FROM t_base ORDER BY t2) RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:05') EVERY(1s) FILL(LINEAR);
## G4 - interp 重复ts
SELECT interp(val) FROM t_dup RANGE('2024-01-01 00:00:01', '2024-01-01 00:00:03') EVERY(1s) FILL(LINEAR);
## G6 - interp 无主键 (expect: error)
SELECT interp(val) FROM (SELECT event_time, val FROM t_event) RANGE('2024-06-01 00:00:01', '2024-06-01 00:00:05') EVERY(1s) FILL(LINEAR);
