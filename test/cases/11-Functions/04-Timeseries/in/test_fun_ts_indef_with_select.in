drop database if exists test_indef_sel;
create database test_indef_sel;
use test_indef_sel;
create table stb (ts timestamp, c1 int, c2 float, c3 bigint) tags (t1 int);
create table ctb1 using stb tags(1);
create table ctb2 using stb tags(2);
create table ctb_empty using stb tags(3);
create table ctb_null using stb tags(4);
create table ctb_single using stb tags(5);
