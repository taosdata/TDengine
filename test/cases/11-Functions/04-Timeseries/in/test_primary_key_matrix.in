-- ---- Section HE: Degraded lag/lead/fill_forward ----
-- HE1-正序
SELECT lag(val, 1) FROM (SELECT event_time, val, st FROM t_event);
SELECT lead(val, 1) FROM (SELECT event_time, val, st FROM t_event);

-- HE2-倒序
SELECT lag(val, 1) FROM (SELECT event_time, val, st FROM t_event_desc);
SELECT lead(val, 1) FROM (SELECT event_time, val, st FROM t_event_desc);

-- HE3-乱序
SELECT lag(val, 1) FROM (SELECT event_time, val, st FROM t_event_rand);
SELECT lead(val, 1) FROM (SELECT event_time, val, st FROM t_event_rand);

-- HE-fill正序
SELECT fill_forward(val) FROM (SELECT event_time, val FROM t_event_fill);
-- HE-fill倒序
SELECT fill_forward(val) FROM (SELECT event_time, val FROM t_event_fill ORDER BY event_time DESC);

-- ---- Section HF: Degraded window functions ----
-- HF1-正序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) INTERVAL(2s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) SESSION(event_time, 1s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) STATE_WINDOW(st);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event) COUNT_WINDOW(2);

-- HF2-倒序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_desc) INTERVAL(2s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_desc) SESSION(event_time, 1s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_desc) STATE_WINDOW(st);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_desc) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_desc) COUNT_WINDOW(2);

-- HF3-乱序
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_rand) INTERVAL(2s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_rand) SESSION(event_time, 1s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_rand) STATE_WINDOW(st);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_rand) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_rand) COUNT_WINDOW(2);

-- HF4-重复ts
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_dup) INTERVAL(2s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_dup) SESSION(event_time, 1s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_dup) STATE_WINDOW(st);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_dup) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
