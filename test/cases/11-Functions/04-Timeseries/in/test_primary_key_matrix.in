-- HF5-NULL(1)
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_null) INTERVAL(2s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_null) SESSION(event_time, 1s);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_null) STATE_WINDOW(st);
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_null) EVENT_WINDOW START WITH val >= 30 END WITH val >= 40;
SELECT count(*) FROM (SELECT event_time, val, st FROM t_event_null) COUNT_WINDOW(2);

-- ---- Cleanup ----
DROP DATABASE IF EXISTS test_pk_matrix;

