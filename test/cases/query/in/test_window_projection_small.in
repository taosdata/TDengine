use test_wp_small;
select _wstart, ts, current from d1001 interval(3s);
select _wstart, ts, current from d1001 session(ts, 2s);
select _wstart, ts, voltage from d1001 state_window(voltage);
select _wstart, ts, current from d1001 event_window start with current >= 1.5 end with current >= 1.9;
select _wstart, ts, current from d1001 count_window(3);
select _wstart, tbname, ts from meters partition by tbname interval(3s) order by tbname, _wstart, ts;
select _wstart, location, ts from meters partition by tbname interval(3s) order by location, _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname session(ts, 2s) order by tbname, _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname state_window(voltage) order by tbname, _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname event_window start with current >= 1.5 end with current >= 1.9 order by tbname, _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname count_window(5) order by tbname, _wstart, ts;
select _wstart, location, groupid, current from meters partition by tbname interval(3s) order by _wstart, location, current;
select _wstart, current * 2 + 1, voltage - 100 from d1001 interval(3s);
select _wstart, sin(current), abs(voltage - 220), ceil(phase * 100) from d1001 interval(3s);
select _wstart, sin(current), ts, current from d1001 interval(3s);
select _wstart, ts + 1s, ts - 1s from d1001 interval(3s);
select _wstart, tbname, current * 2, voltage + phase from meters partition by tbname interval(3s) order by tbname, _wstart, 3;
select _wstart, tbname, concat(location, '-zone') from meters partition by tbname interval(3s) order by tbname, _wstart;
select _wstart, _wend, _wduration, ts, current from d1001 interval(3s);
select _wstart, _wend, _wduration, ts from d1001 session(ts, 2s);
select _wstart, ts, current from d1001 where ts >= '2024-01-01 00:00:00' and ts < '2024-01-01 00:00:15' interval(3s) fill(null);
select _wstart, ts, current from d1001 where ts >= '2024-01-01 00:00:00' and ts < '2024-01-01 00:00:15' interval(3s) fill(none);
select _wstart, ts, current, voltage, phase from d1001 interval(3s);
select _wstart, ts, current from d1001 interval(60s);
select _wstart, ts, current, voltage from d_null interval(3s);
select _wstart, ts, current from d1001 where ts >= '2024-01-01 00:00:03' and ts < '2024-01-01 00:00:10' interval(3s);
select _wstart, ts, current from d1001 where current > 1.5 interval(3s);
select _wstart, ts, current from d1001 interval(3s) having _wstart >= '2024-01-01 00:00:09';
select _wstart, ts, current from d1001 interval(3s) having current > 1.5;
select _wstart, tbname, ts from meters partition by tbname interval(3s) having location = 'Beijing' order by _wstart, ts;
select _wstart, tbname, location, ts from meters partition by tbname interval(3s) having location = 'Beijing' order by _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname interval(3s) having tbname = 'd1001' order by _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname interval(3s) having location = 'Nonexistent';
select _wstart, ts, current from d1001 interval(3s) having length(location) > 5;
select _wstart, ts, current from d1001 interval(3s) order by _wstart;
select _wstart, ts, current from d1001 interval(3s) limit 5;
select _wstart, ts, current from d1001 interval(3s) limit 3 offset 5;
select count(*) from (select _wstart, tbname, ts from meters partition by tbname interval(3s) slimit 1);
select _wstart, ts, current from d1001 where current > 1.0 interval(3s) having current > 1.5;
select _wstart, ts, current from d1001 where current > 1.0 interval(3s) order by _wstart limit 5;
select _wstart, ts, current from d1001 interval(3s) order by _wstart, ts;
select * from (select _wstart, ts, current from d1001 interval(3s)) where current > 1.5;
select avg(current) from (select _wstart, ts, current from d1001 interval(3s));
select _wstart, tbname, ts from meters partition by tbname session(ts, 2s) having location = 'Beijing' order by _wstart, ts;
select _wstart, tbname, ts, voltage from meters partition by tbname state_window(voltage) having location = 'Beijing' order by _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname count_window(5) having location = 'Beijing' order by _wstart, ts;
select _wstart, tbname, ts, current from meters partition by tbname interval(3s) having location = 'Beijing' and current > 1.5 order by tbname, _wstart, ts;
select _wstart, tbname, ts from meters partition by tbname interval(3s) having location = 'Beijing' or location = 'Shenzhen' order by tbname, _wstart, ts;
select _wstart, ts, csum(current) from d1001 interval(3s) having _wstart >= '2024-01-01 00:00:09';
select _wstart, ts, csum(current) from d1001 interval(3s) having current > 1.5;
select _wstart, ts, csum(current) from meters partition by tbname interval(3s) having location = 'Beijing' order by _wstart, ts;
select _wstart, ts, csum(current) from meters partition by tbname interval(3s) having location = 'Beijing' order by _wstart, ts;
select _wstart, ts from d1001 interval(3s) having location = 'Shanghai';
select _wstart, ts, current from d1001 session(ts, 3s) having location = 'Beijing';
select _wstart, ts, voltage from d1002 state_window(voltage) having location = 'Shanghai';
select _wstart, ts, current from d1001 count_window(3) having location = 'Beijing';
select _wstart, ts, current from d1001 where current > 1.5 interval(3s) having location = 'Beijing';
select _wstart, ts, current from d1001 interval(3s) having location = 'Beijing' and current > 1.5;
select _wstart, ts, voltage from d1002 state_window(voltage) having location = 'Beijing';
select _wstart, ts from d1001 interval(3s) having current > 1.5;
select _wstart, ts from d1001 session(ts, 3s) having current > 1.5;
select _wstart, ts, current from d1001 interval(3s) having current > 1.5 order by _wstart, ts;
select _wstart, ts, current from d1001 interval(3s) having current > 1.0 and current < 1.5 order by _wstart, ts;
select _wstart, tbname, ts, current from meters partition by tbname interval(3s) having location = 'Beijing' order by tbname, _wstart, ts;
select avg(current) from (select _wstart, ts, current from d1001 interval(3s) having current > 1.5);
select _wstart, ts, current from d1001 where ts >= '2024-01-01' and ts < '2024-01-01 00:00:13' interval(3s) fill(null) having current > 1.5;
select count(*) from (select _wstart, ts, current from d1001 interval(3s) union all select _wstart, ts, current from d1002 interval(3s));
select _wstart, ts, voltage from d1002 interval(3s);
select _wstart, ts, current from d1003 interval(3s);
select _wstart, ts, voltage from d1002 state_window(voltage);
select _wstart, _wend from d1001 interval(3s);
select ts, current from d1001;
select _wstart, avg(current), count(*), sum(voltage) from d1001 interval(3s);
select ts, csum(current) from d1001 interval(3s);
select _wstart, sin(current), csum(current) from d1001 interval(3s);
select tbname, _wstart, avg(current) from meters partition by tbname interval(3s) order by tbname, _wstart;
select _wstart, ts, current from d1001 interval(3s) order by _wstart desc;
select _wstart, ts, current from d1001 where current > 1.0 interval(3s) having current > 1.5;
select _wstart, ts, current from d1001 where current > 1.0 interval(3s) order by _wstart limit 5;
select _wstart, ts, current from d1001 interval(3s) having abs(current) > 1.5;
select count(*) from ((select _wstart, ts from d1001 interval(3s)) union all (select _wstart, ts from d1002 interval(3s)));
