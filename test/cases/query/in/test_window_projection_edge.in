drop database if exists test_wp_edge;
create database test_wp_edge vgroups 1;
use test_wp_edge;
create table meters (ts timestamp, current float, voltage int, phase float) tags(location nchar(64), groupid int);
create table d_empty using meters tags('Empty', 9);
create table d_single using meters tags('Single', 9);
insert into d_single values('2024-01-01 00:00:00', 1.5, 220, 0.3);
select _wstart, ts from d_empty interval(3s);
select _wstart, ts, current from d_single interval(3s);
select _wstart, ts, current from d_single session(ts, 3s);
select _wstart, ts, voltage from d_single state_window(voltage);
select _wstart, ts, current from d_single count_window(3);
select _wstart, ts, current from d_single event_window start with current >= 1.0 end with current >= 2.0;
