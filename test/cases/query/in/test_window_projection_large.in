use test_wp_inans;
select _wstart, ts, current, voltage from d1 interval(60s) order by _wstart, ts limit 5;
select _wstart, ts, current from d1 session(ts, 2s) order by _wstart, ts limit 5;
select _wstart, ts, voltage from d1 state_window(voltage) order by _wstart, ts limit 5;
select _wstart, ts, current from d1 count_window(100) order by _wstart, ts limit 5;
select _wstart, ts, current from d1 event_window start with current > 1.5 end with current < 1.01 order by _wstart, ts limit 10;
select _wstart, tbname, ts, current from meters partition by tbname interval(60s) order by tbname, _wstart, ts;
select _wstart, groupid, tbname, ts from meters partition by groupid interval(60s) order by groupid, tbname, _wstart, ts;
select _wstart, groupid, tbname, ts from meters partition by groupid session(ts, 2s) order by groupid, tbname, _wstart, ts;
select _wstart, groupid, tbname, ts, voltage from meters partition by groupid state_window(voltage) order by groupid, tbname, _wstart, ts;
select _wstart, groupid, tbname, ts from meters partition by groupid count_window(100) order by groupid, tbname, _wstart, ts;
select _wstart, tbname, location, groupid, ts, current from meters partition by tbname interval(5000s) order by tbname, _wstart, ts limit 6;
select _wstart, ts, current*2+1 as expr from d1 interval(60s) order by _wstart, ts limit 3;
select _wstart, ts, abs(current - 1.5) as diff from d1 interval(60s) order by _wstart, ts limit 3;
select _wstart, ts, current + voltage as cv, current * phase as cp from d1 interval(60s) order by _wstart, ts limit 3;
select _wstart, tbname, length(location) as loc_len, ts from meters partition by tbname interval(5000s) order by tbname, _wstart, ts limit 3;
select _wstart, ts, current from d1 where ts >= '2024-01-01 00:30:00' and ts < '2024-01-01 01:00:00' interval(60s) order by _wstart, ts;
select _wstart, ts, current from d1 interval(60s) having current > 1.3 and current < 1.7 order by _wstart, ts;
select _wstart, ts, current from d1 where ts < '2024-01-01 01:00:00' interval(60s) having current > 1.0 order by _wstart, ts;
select _wstart, ts, current from d1 interval(60s) order by _wstart, ts limit 50 offset 10;
select _wstart, tbname, ts, current from meters partition by tbname interval(60s) having location = 'Beijing' order by tbname, _wstart, ts limit 20;
select count(*) from (select _wstart, tbname, ts, current from meters partition by tbname interval(60s) slimit 1);
select _wstart, ts, current from d1 interval(60s) having location = 'Beijing' order by _wstart, ts;
select _wstart, ts, current from d1 interval(60s) having location = 'Shanghai' order by _wstart, ts;
select _wstart, ts, current from d1 interval(60s) having groupid = 1 order by _wstart, ts;
select _wstart, ts, current from d1 session(ts, 2s) having location = 'Beijing' order by _wstart, ts;
select _wstart, ts, voltage from d1 state_window(voltage) having groupid = 1 order by _wstart, ts;
select _wstart, ts, current from d1 count_window(100) having location = 'Beijing' order by _wstart, ts;
select avg(current), min(current), max(current) from (select _wstart, ts, current from d1 interval(60s));
select avg(current), min(current), max(current) from (select _wstart, ts, current from d1 session(ts, 2s));
select avg(current), min(current), max(current) from (select _wstart, ts, current from d1 count_window(100));
select _wstart, ts, current from (select _wstart, ts, current from d1 interval(60s)) where current > 1.5 and current < 1.8 order by _wstart, ts;
select _wstart as ws, count(*) as cnt from (select _wstart, ts, current from d1 interval(300s)) group by _wstart order by ws limit 5;
select * from (select _wstart, ts, current from d1 interval(60s)) where current > 1.0 order by _wstart;
select _wstart, ts, current from d1 where ts between '2024-01-01 00:00:00' and '2024-01-01 00:05:00' interval(1s) fill(null) order by _wstart, ts;
select _wstart, ts, current from d1 where ts between '2024-01-01 00:00:00' and '2024-01-01 00:05:00' interval(1s) fill(value) order by _wstart, ts;
select _wstart, ts, current from d1 where ts between '2024-01-01 00:00:00' and '2024-01-01 00:05:00' interval(1s) fill(null_f) order by _wstart, ts;
select _wstart, ts, current from d1 interval(1s) order by _wstart, ts;
select _wstart, ts, current from d1 interval(1d) order by _wstart, ts;
select _wstart, ts, current from d1 count_window(10000) order by _wstart, ts;
select _wstart, ts, current from d1 count_window(2) order by _wstart, ts;
select _wstart, _wend, ts, current, voltage, phase from d1 interval(60s) order by _wstart, ts limit 2;
select _wstart, _wend, _wduration, ts from d1 interval(60s) order by _wstart, ts limit 2;
select _wstart, groupid, tbname, ts, current from meters partition by groupid interval(5000s) order by groupid, tbname, _wstart, ts limit 4;
select _wstart, groupid, tbname, ts, current from meters partition by groupid interval(60s) having groupid = 1 order by tbname, _wstart, ts;
select _wstart, groupid, tbname, ts, current*2 as c2 from meters partition by groupid interval(60s) order by groupid, tbname, _wstart, ts;
select _wstart, groupid, ts, current from meters where current > 1.5 partition by groupid interval(60s) having groupid = 2 order by _wstart, ts;
select avg(current), groupid from (select _wstart, groupid, ts, current from meters partition by groupid interval(60s)) group by groupid order by groupid;
select _wstart, tbname, ts, current from meters partition by tbname session(ts, 2s) order by tbname, _wstart, ts;
select _wstart, tbname, ts, voltage from meters partition by tbname state_window(voltage) order by tbname, _wstart, ts;
select _wstart, tbname, ts, current from meters partition by tbname count_window(500) order by tbname, _wstart, ts;
select _wstart, tbname, ts, current from meters partition by tbname event_window start with current > 1.5 end with current < 1.01 order by tbname, _wstart, ts;
