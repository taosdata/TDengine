use test;

select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) order by t1, ws;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) having count(*) > 1 order by t1, ws;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) having sum(v) > 20 order by t1, ws;
select tbname, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by tbname external_window((select ts, endtime, mark from ext_cx_win) w) order by tbname, ws;
select tbname, cast(_wstart as bigint) as ws, count(*) as c, max(v)-min(v) as span from ext_cx_src partition by tbname external_window((select ts, endtime, mark from ext_cx_win) w) having max(v)-min(v) >= 0 order by tbname, ws;
select t1, cast(_wstart as bigint) as ws, w.wc, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select _wstart, _wend, count(*) as wc from ext_cx_win_part partition by t1 interval(10m)) w) order by t1, ws;
select t1, cast(_wstart as bigint) as ws, w.wc, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select _wstart, _wend, count(*) as wc from ext_cx_win_part partition by t1 interval(10m)) w) having count(*) >= 1 order by t1, ws;
select t1, cast(_wstart as bigint) as ws, cast(ts as bigint) as ts64 from ext_cx_src partition by t1 external_window((select _wstart, _wend from ext_cx_win_part partition by t1 interval(10m)) w) order by t1, ts;
select tbname, cast(_wstart as bigint) as ws, cast(ts as bigint) as ts64 from ext_cx_src partition by tbname external_window((select ts, endtime, mark from ext_cx_win) w) order by tbname, ts desc limit 8;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src where v >= 12 partition by t1 external_window((select ts, endtime, mark from ext_cx_win where mark <= 103) w) having sum(v) > 10 order by t1, ws;
select tbname, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src where v >= 20 partition by tbname external_window((select ts, endtime, mark from ext_cx_win) w) order by tbname, ws;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) order by c desc, t1, ws limit 6;
