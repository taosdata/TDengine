use test_ext_fill_having_order;

select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(null) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_empty external_window((select ts, endtime, mark from win) w) fill(value_f, 777) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_empty external_window((select ts, endtime, mark from win) w) fill(null_f) order by ws;
select t1, cast(_wstart as bigint) as ws, sum(v) as sv from src partition by t1 external_window((select ts, endtime, mark from win) w) fill(value, 777) order by t1, ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) order by ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) = 777) order by ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(prev) having(sum(v) is not null) order by ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src_empty external_window((select ts, endtime, mark from win) w) fill(null_f) order by ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src_empty external_window((select ts, endtime, mark from win) w) fill(value_f, 777) order by ws;
select cast(_wstart as bigint) as ws, w.mark, sum(v) as sv from src partition by t1 external_window((select ts, endtime, mark from win) w) fill(value, 777) order by ws, sv;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(prev) having(sum(v) is not null) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(prev) having(sum(v) > 100) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(prev) having(sum(v) > 20) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) >= 100) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) = 777) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) != 777) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) <= 777) order by ws;
select cast(_wstart as bigint) as ws, sum(v) as sv from src_1 external_window((select ts, endtime, mark from win) w) fill(null) having(sum(v) is not null) order by ws;
select t1, cast(_wstart as bigint) as ws, sum(v) as sv from src partition by t1 external_window((select ts, endtime, mark from win) w) fill(prev) having(sum(v) > 20) order by t1, ws;
select t1, cast(_wstart as bigint) as ws, sum(v) as sv from src partition by t1 external_window((select ts, endtime, mark from win) w) fill(value, 777) having(sum(v) = 777) order by t1, ws;
