use test;

select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, c;
select cast(_wstart as bigint) as ws, sum(v) as sv from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, sv;
select cast(_wstart as bigint) as ws, min(v) as minv, max(v) as maxv from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, maxv;
select cast(_wstart as bigint) as ws, avg(v) as avgv from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, avgv;
select cast(_wstart as bigint) as ws, first(v) as fv, last(v) as lv from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, lv;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv, min(v) as minv, max(v) as maxv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) order by t1, ws;
select tbname, cast(_wstart as bigint) as ws, avg(v) as avgv, first(v) as fv, last(v) as lv from ext_cx_src partition by tbname external_window((select ts, endtime, mark from ext_cx_win) w) order by tbname, ws;
select t1, cast(_wstart as bigint) as ws, w.wc, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select _wstart, _wend, count(*) as wc from ext_cx_win_part partition by t1 interval(10m)) w) order by t1, ws;
select cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv, avg(v2) as avgv2 from ext_cx_src where v >= 12 external_window((select ts, endtime, mark from ext_cx_win where mark <= 103) w) order by ws;
select t1, cast(_wstart as bigint) as ws, count(*) as c, sum(v) as sv from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win) w) having count(*) >= 1 order by t1, ws;
select cast(_wstart as bigint) as ws, stddev(v) vv from ext_cx_src external_window((select ts, endtime, mark from ext_cx_win) w) order by ws, vv;

select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by t1 external_window((select ts, endtime, mark from ext_cx_win partition by mark) w) order by ws, c;
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_win_part partition by t1 external_window((select ts, endtime, mark from ext_cx_win partition by mark) w) order by ws, c;
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by v2 external_window((select ts, endtime, mark from ext_cx_win partition by mark) w) order by ws, c;
# 目前，qFetchRemoteNode 取到子查询的数据就没有分组。原因是子查询的计划里，有 sort 排序，sort 排序过程导致groupid 没有了，下边是子查询的计划，供参考，请查看计划，让sort 排序依然能保持 block 块里的
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by v2 external_window((select first(ts) fts, first(endtime), mark from ext_cx_win partition by mark) w) order by ws, c;
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by v2 external_window((select first(ts) fts, first(endtime), mark from ext_cx_win group by mark) w) order by ws, c;
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by v2 external_window((select first(ts) fts, first(endtime), mark from ext_cx_win partition by mark order by fts) w) order by ws, c;
select cast(_wstart as bigint) as ws, count(*) as c from ext_cx_src partition by v2 external_window((select first(ts) fts, first(endtime), mark from ext_cx_win group by mark order by fts) w) order by ws, c;

