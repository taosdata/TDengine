use test;
select _wstart, _wend, w.v2, w.v1, count(*) from st1_1 external_window((select ts, endtime, v1, v2 from ext_win_subq_1) w);
select _wstart, _wend, w.v1, ts from st1_1 external_window((select ts, endtime, v1  from ext_win_subq_1) w);
select _wstart, _wend, w.v1+1, ts from st1_1 external_window((select ts, endtime, v1  from ext_win_subq_1) w);
select _wstart, _wend, w.v1, count(*) from st1_1 partition by dev  external_window((select ts, endtime, v1  from ext_win_subq_1) w);
select _wstart, _wend, w.v1, count(*), dev from st1_1 partition by dev  external_window((select ts, endtime, v1  from ext_win_subq_1) w);
select _wstart, _wend, w.v1, count(*), v2 from st1_1 partition by v2  external_window((select ts, endtime, v1  from ext_win_subq_1) w) limit 20;
select _wstart, _wend, w.v1, count(*), v2 from st1_1 partition by v2  external_window((select ts, endtime, v1  from ext_win_subq_1) w) order by v2 desc limit 20;
select _wstart, _wend, w.v1, count(*), (select count(*) from (select ts from st1_1) t) as total_rows from st1_1 external_window((select ts, endtime, v1 from ext_win_subq_1) w);
select _wstart, _wend, w.v1, count(*), v2, (select count(*) from (select ts from st1_1) t) as total_rows from st1_1 partition by v2 external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by v2 desc limit 20;
select _wstart, _wend, w.fc1 + 1, ts from st1_1 external_window((select ts, ts+1 as e, first(c1) fc1 from st2) w);
select _wstart, _wend, w.fc1, count(*) from st1_1 external_window((select ts, ts+1 as e, first(c1) fc1 from st2) w);
select _wstart, _wend, w.fc1, ts from st1_1 external_window((select ts, ts+1 as e, first(c1) fc1 from st2) w);
select _wstart, _wend, _wduration, ts from st1_1 external_window((select ts, ts+1 as e, first(c1) c1 from st2) w);
select _wstart, _wend, ts from st1_1 external_window((select ts, ts+1 as e, first(c1) c1 from st2 where c1 is not null) w);
select _wstart, _wend, ts, cast(ts as bigint) - cast(_wstart as bigint) as delta from st1_1 external_window((select ts, ts+1 as e, first(c1) c1 from st2) w);
select _wstart, count(*) from st1_1 external_window((select ts, ts+10 as e, min(c1) mc1 from st2) w);
select _wstart, _wend, w.mc1, * from st1_1 external_window((select ts, ts+10 as e, min(c1) mc1 from st2) w);
select _wstart, _wend, w.mc1, dev from st1_1 partition by dev external_window((select ts as s, ts+20 as e, min(c1) mc1 from st2) w);
select _wstart, _wend, w.mc1, v2 from st1_1 partition by v2 external_window((select ts as s, ts+20 as e, min(c1) mc1 from st2) w) order by v2 desc limit 10;
select _wstart, _wend, w.fc1*2 as f2, count(*), v2 from st1_1 partition by v2 external_window((select ts, ts+15 as e, first(c1) fc1 from st2) w) order by _wstart desc limit 20;
select _wstart, _wend, w.fc1, count(*), (select count(*) from (select ts from st1_1) t) as total_rows from st1_1 external_window((select ts, ts+25 as e, first(c1) fc1 from st2) w);
select _wstart, _wend, w.fc1, count(*), dev from st1_1 partition by dev external_window((select ts, ts+5 as e, first(c1) fc1 from st2) w);
select _wstart, _wend, w.fc1, count(*), v2 from st1_1 partition by v2 external_window((select ts, ts+5 as e, first(c1) fc1 from st2) w) limit 20;
select _wstart, count(*) from st1_1 external_window((select ts, ts+5 as e from st2) w);
select _wstart, _wend, w.c2, count(*) from st1_1 external_window((select ts, ts+30 as e, c2 from st2) w);
select _wstart, _wend, count(*) from st1_1 external_window((select ts, ts+5 as e from st2 order by ts) w);
select _wstart, _wend, w.v1, ts from st1_1 external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by ts desc limit 6;
select _wstart, _wend, w.v1, cast(ts as bigint) from st1_1 external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by ts desc limit 6;
select _wstart, _wend, w.v1, cast(ts as bigint) - cast(_wstart as bigint) as delta from st1_1 external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by ts desc limit 6;
select _wstart, _wend, w.v1, count(*), sum(v1) as sv1 from st1_1 where ts >= '2020-05-13 11:19:00.000' and ts <= '2020-05-13 11:26:00.000' external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by _wstart;
select _wstart, _wend, w.v1, count(*), sum(v1) as sv1 from st1_1 external_window((select ts, endtime, v1 from ext_win_subq_1 where ts >= '2020-05-13 11:19:00.000' and ts <= '2020-05-13 11:26:00.000') w) order by _wstart;
select _wstart, _wend, w.v1, count(*), sum(v1) as sv1, dev from st1_1 partition by dev external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by _wstart desc limit 3;
select _wstart, _wend, w.v1, count(*), sum(v1) as sv1, dev from st1_1 partition by dev external_window((select ts, endtime, v1 from ext_win_subq_1) w) order by _wstart desc;
select cast(_wstart as bigint) as ws, count(*) as c from ext_src external_window((select _wstart, _wend, count(*) as wc from ext_win partition by t1 interval(10m)) w) order by ws;
select t1, cast(_wstart as bigint) as ws, count(*) as c from ext_src external_window((select _wstart, _wend, count(*) as wc from ext_win partition by t1 interval(10m)) w) order by ws;