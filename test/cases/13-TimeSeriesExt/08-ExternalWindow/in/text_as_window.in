use test;
select cast(_wstart as bigint) as ws, cast(_wend as bigint) as we, count(*) as c, sum(v1) as sv from st1_1 external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000') ('2020-05-13 10:30:00.000', '2020-05-13 10:59:00.000') ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000') win_t) w) order by ws;
select cast(_wstart as bigint) as ws, w.mark, count(*) as c from st1_1 external_window((select ts, endtime, mark from TEXT(ts TIMESTAMP, endtime TIMESTAMP, mark INT) values ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000', 1) ('2020-05-13 10:30:00.000', '2020-05-13 10:59:00.000', 2) ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000', 3) win_t) w) order by ws;
select cast(_wstart as bigint) as ws, w.mark, count(*) as c from st1_1 external_window((select ts, endtime, mark from TEXT(ts TIMESTAMP, endtime TIMESTAMP, mark INT) values ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000', 1) ('2020-05-13 10:30:00.000', '2020-05-13 10:59:00.000', 2) ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000', 3) win_t where mark >= 2) w) order by ws;
select tbname, cast(_wstart as bigint) as ws, count(*) as c from st1 partition by tbname external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 10:00:00.000', '2020-05-13 11:39:00.000') ('2020-05-13 11:40:00.000', '2020-05-13 13:19:00.000') win_t) w) order by tbname, ws limit 4;
select cast(_wstart as bigint) as ws, w.mark, cast(ts as bigint) as ts64, v1 from st1_1 external_window((select ts, endtime, mark from TEXT(ts TIMESTAMP, endtime TIMESTAMP, mark INT) values ('2020-05-13 10:00:00.000', '2020-05-13 10:02:00.000', 10) ('2020-05-13 11:37:00.000', '2020-05-13 11:39:00.000', 20) win_t) w) order by ws, ts64;
select cast(_wstart as bigint) as ws, count(*) as c from st1_1 external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000') ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000') win_t) w) order by ws;
select cast(_wstart as bigint) as ws, count(*) as c, sum(v1) as sv from st1_1 external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 10:00:00.000', '2020-05-13 11:39:00.000') win_t) w);
select cast(_wstart as bigint) as ws, count(*) as c from st1_1 external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 12:00:00.000', '2020-05-13 13:00:00.000') win_t) w);
select cast(_wstart as bigint) as ws, count(*) as c from st1_1 where ts >= '2020-05-13 10:15:00.000' external_window((select ts, endtime from TEXT(ts TIMESTAMP, endtime TIMESTAMP) values ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000') ('2020-05-13 10:30:00.000', '2020-05-13 10:59:00.000') ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000') win_t) w) order by ws;
select cast(_wstart as bigint) as ws, w.mark * 10 as mark10, count(*) as c from st1_1 external_window((select ts, endtime, mark from TEXT(ts TIMESTAMP, endtime TIMESTAMP, mark INT) values ('2020-05-13 10:00:00.000', '2020-05-13 10:29:00.000', 5) ('2020-05-13 11:00:00.000', '2020-05-13 11:39:00.000', 7) win_t) w) order by ws;
