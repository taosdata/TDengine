set max_binary_display_width 300;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_0_vtb where ts >= (select lower_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) and ts < (select upper_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_0_vtb where ts >= (select lower_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_0_vtb where ts < (select upper_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_0_vtb where ts = (select exact_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_multi_vtb where ts >= (select lower_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) and ts < (select upper_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.vstb_0 where ts >= (select lower_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) and ts <= (select mid_ts from test_vtable_ts_pushdown_origin.bound_t limit 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_0_vtb where ts >= (select first(lower_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) and ts < (select last(upper_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ntb_multi_vtb where ts >= (select first(lower_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) and ts < (select last(upper_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.vstb_0 where ts = (select first(exact_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) order by ts;
explain verbose true select * from test_vtable_ts_pushdown_vtb.ctb_0_vtb where ts = (select last(exact_ts) from test_vtable_ts_pushdown_origin.bound_filter_t where group_id = 1) order by ts;
