taos> SELECT cat, cnt FROM (SELECT cat, COUNT(*) AS cnt FROM TEXT(ts TIMESTAMP, cat VARCHAR(8)) VALUES ('2024-01-01 00:00:00', 'X') ('2024-01-02 00:00:00', 'Y') ('2024-01-03 00:00:00', 'X') t_pb_gb GROUP BY cat) PARTITION BY cat ORDER BY cat;
    cat     |          cnt          |
=====================================
 X          |                     2 |
