use text_src_db;
SELECT _wstart, _wend, COUNT(*), SUM(v) FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-05 00:00:00', 30) ('2024-01-06 00:00:00', 40) t_ses1 SESSION(ts, 2d);
SELECT _wstart, COUNT(*), MAX(v) FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-08 00:00:00', 20) ('2024-01-15 00:00:00', 30) ('2024-01-22 00:00:00', 40) t_ses2 SESSION(ts, 5d) ORDER BY _wstart;
SELECT _wstart, _wend, SUM(v) FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) ('2024-01-10 00:00:00', 50) ('2024-01-11 00:00:00', 60) t_ses3 SESSION(ts, 3d) ORDER BY _wstart;
SELECT _wstart, COUNT(*), SUM(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-05 00:00:00', 30) ('2024-01-06 00:00:00', 40) t_iv1_i) sub INTERVAL(1d);
SELECT _wstart, SUM(v), MAX(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) ('2024-01-03 00:00:00', 300) t_iv2_i) sub INTERVAL(1d) ORDER BY _wstart;
SELECT _wstart, COUNT(*), SUM(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-03 00:00:00', 20) ('2024-01-05 00:00:00', 30) t_ivs_i) sub INTERVAL(3d, 2d);
SELECT _wstart, _wend, COUNT(*), SUM(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 5) ('2024-01-02 00:00:00', 15) ('2024-01-03 00:00:00', 8) ('2024-01-04 00:00:00', 20) t_ev1_i) sub EVENT_WINDOW START WITH v < 10 END WITH v >= 15;
SELECT _wstart, _wend, SUM(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 100) ('2024-01-03 00:00:00', 2) ('2024-01-04 00:00:00', 200) t_ev2_i) sub EVENT_WINDOW START WITH v < 10 END WITH v >= 100 ORDER BY _wstart;
SELECT _wstart, _wend, COUNT(*), FIRST(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 1) ('2024-01-03 00:00:00', 2) ('2024-01-04 00:00:00', 2) t_sw1_i) sub STATE_WINDOW(v);
SELECT _wstart, _wend, COUNT(*), LAST(v) FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-03 00:00:00', 20) ('2024-01-04 00:00:00', 10) t_sw2_i) sub STATE_WINDOW(v) ORDER BY _wstart;
SELECT _wstart, cat, COUNT(*) FROM (SELECT ts, cat, v FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-06 00:00:00', 'A', 20) ('2024-01-01 00:00:00', 'B', 30) ('2024-01-08 00:00:00', 'B', 40) t_pbs_i) sub PARTITION BY cat SESSION(ts, 2d) ORDER BY cat, _wstart;
SELECT _wstart, cat, COUNT(*), SUM(v) FROM (SELECT ts, cat, v FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'A', 20) ('2024-01-05 00:00:00', 'B', 30) ('2024-01-06 00:00:00', 'B', 40) t_pbi_i) sub PARTITION BY cat INTERVAL(1d) ORDER BY cat, _wstart;
