CREATE DATABASE IF NOT EXISTS file_src_db;
USE file_src_db;
SELECT ts, c1, c2, c3, c4 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f;
SELECT * FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f;
SELECT ts FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f;
SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_unsorted.csv', 'ts TIMESTAMP, c1 INT') f;
SELECT ts, c1, c2, label FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_header.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, label VARCHAR(16)', header=true) f;
SELECT ts, c1, c2, c3, c4 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f LIMIT 2;
SELECT ts, c1, c2, c3, c4 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f ORDER BY c1 DESC;
SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f WHERE c1 > 15;
SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f WHERE c1 BETWEEN 10 AND 25;
SELECT ts, c1, c2, c3, c4 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f WHERE c3 = true;
SELECT ts, c1 FROM (SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_nulls.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE') src) sub WHERE c1 IS NOT NULL;
SELECT ts, c1 FROM (SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_nulls.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE') src) sub WHERE c1 IS NULL;
SELECT MAX(c1), MIN(c2) FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f;
SELECT SUM(c1), COUNT(c1) FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f;
SELECT MAX(c1), MIN(c1) FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') f WHERE c1 > 10;
SELECT * FROM (SELECT ts, c1 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_basic.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)') src) sub WHERE c1 > 15;
SELECT ts, c1, c2 FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_nulls.csv', 'ts TIMESTAMP, c1 INT, c2 DOUBLE') f;
