use text_src_db;
SELECT cat, COUNT(*) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) ('2024-01-04 00:00:00', 'B', 40) t_gb1 GROUP BY cat ORDER BY cat;
SELECT cat, SUM(v), COUNT(*) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) ('2024-01-04 00:00:00', 'B', 40) t_gb2 GROUP BY cat ORDER BY cat;
SELECT cat, MAX(v), MIN(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) ('2024-01-04 00:00:00', 'B', 40) t_gb3 GROUP BY cat ORDER BY cat;
SELECT cat, SUM(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) t_gb4 WHERE v > 10 GROUP BY cat ORDER BY cat;
SELECT cat, SUM(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) t_gb5 GROUP BY cat HAVING SUM(v) > 15 ORDER BY cat;
SELECT k1, k2, COUNT(*) FROM TEXT(ts TIMESTAMP, k1 VARCHAR(4), k2 INT, v INT) VALUES ('2024-01-01 00:00:00', 'A', 1, 10) ('2024-01-02 00:00:00', 'A', 2, 20) ('2024-01-03 00:00:00', 'B', 1, 30) t_gb6 GROUP BY k1, k2 ORDER BY k1, k2;
SELECT cat, cnt FROM (SELECT cat, COUNT(*) AS cnt FROM TEXT(ts TIMESTAMP, cat VARCHAR(8)) VALUES ('2024-01-01 00:00:00', 'X') ('2024-01-02 00:00:00', 'Y') ('2024-01-03 00:00:00', 'X') t_gb7_i GROUP BY cat) sub WHERE cnt > 1;
SELECT score, COUNT(*) FROM TEXT(ts TIMESTAMP, score INT, label VARCHAR(8)) VALUES ('2024-01-01 00:00:00', 100, 'a') ('2024-01-02 00:00:00', 200, 'b') ('2024-01-03 00:00:00', 100, 'c') t_gb8 GROUP BY score ORDER BY score;
SELECT cat, v FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) t_pb1 PARTITION BY cat ORDER BY cat, ts;
SELECT cat, SUM(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) t_pb2 PARTITION BY cat ORDER BY cat;
SELECT cat, SUM(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) t_pb3 PARTITION BY cat HAVING SUM(v) > 15 ORDER BY cat;
SELECT cat, COUNT(*), MAX(v) FROM TEXT(ts TIMESTAMP, cat VARCHAR(8), v INT) VALUES ('2024-01-01 00:00:00', 'A', 10) ('2024-01-02 00:00:00', 'B', 20) ('2024-01-03 00:00:00', 'A', 30) ('2024-01-04 00:00:00', 'B', 5) t_pb4 PARTITION BY cat ORDER BY cat;
SELECT cat, cnt FROM (SELECT cat, COUNT(*) AS cnt FROM TEXT(ts TIMESTAMP, cat VARCHAR(8)) VALUES ('2024-01-01 00:00:00', 'X') ('2024-01-02 00:00:00', 'Y') ('2024-01-03 00:00:00', 'X') t_pb_gb GROUP BY cat) PARTITION BY cat ORDER BY cat;
