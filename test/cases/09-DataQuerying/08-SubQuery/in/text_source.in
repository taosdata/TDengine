use text_src_db;
DROP TABLE IF EXISTS ref_items;
CREATE TABLE ref_items (ts TIMESTAMP, id INT, label VARCHAR(32));
INSERT INTO ref_items VALUES ('2024-01-01 00:00:00', 1, 'alpha')('2024-01-02 00:00:00', 2, 'beta')('2024-01-03 00:00:00', 3, 'gamma');
SELECT ts, a FROM TEXT(ts TIMESTAMP, a BIGINT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) t1;
SELECT ts, c1, c2, c3, c4 FROM TEXT(ts TIMESTAMP, c1 INT, c2 DOUBLE, c3 BOOL, c4 VARCHAR(32)) VALUES ('2024-01-01 00:00:00', 10, 3.14, true, 'abc') t2;
SELECT ts FROM TEXT(ts TIMESTAMP) VALUES ('2024-01-01 00:00:00') ('2024-01-02 00:00:00') ('2024-01-03 00:00:00') t3;
SELECT ts, b FROM TEXT(ts TIMESTAMP, b INT) VALUES ('2024-01-01 00:00:00', NULL) ('2024-01-02 00:00:00', 42) t4;
SELECT * FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a BIGINT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) inner_t) sub;
SELECT ts FROM TEXT(ts TIMESTAMP) VALUES ('2024-03-01 00:00:00');
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 3) t7 WHERE a > 1;
SELECT ts, v1, v2, v3, v4 FROM TEXT(ts TIMESTAMP, v1 TINYINT, v2 SMALLINT, v3 INT, v4 BIGINT) VALUES ('2024-01-01 00:00:00', 127, 32767, 2147483647, 9223372036854775807) t8;
SELECT ts, f1, f2 FROM TEXT(ts TIMESTAMP, f1 FLOAT, f2 DOUBLE) VALUES ('2024-01-01 00:00:00', 1.5, 2.718281828) ('2024-01-02 00:00:00', -3.14, 0.0) t9;
SELECT ts, s1, s2 FROM TEXT(ts TIMESTAMP, s1 VARCHAR(64), s2 NCHAR(64)) VALUES ('2024-01-01 00:00:00', 'hello world', 'nchar_val') ('2024-01-02 00:00:00', 'foo', 'bar') t10;
SELECT ts, b1 FROM TEXT(ts TIMESTAMP, b1 BOOL) VALUES ('2024-01-01 00:00:00', true) ('2024-01-02 00:00:00', false) ('2024-01-03 00:00:00', NULL) t11;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 5) ('2024-01-02 00:00:00', 3) ('2024-01-03 00:00:00', 8) ('2024-01-04 00:00:00', 1) t12 ORDER BY a DESC;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-03 00:00:00', 30) ('2024-01-04 00:00:00', 40) ('2024-01-05 00:00:00', 50) t13 LIMIT 3;
SELECT ts, a, b FROM TEXT(ts TIMESTAMP, a INT, b VARCHAR(16)) VALUES ('2024-01-01 00:00:00', NULL, 'present') ('2024-01-02 00:00:00', 99, NULL) t14;
SELECT ts FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 3) inner_t WHERE a >= 2) sub;
SELECT ts, u1, u2, u3, u4 FROM TEXT(ts TIMESTAMP, u1 TINYINT UNSIGNED, u2 SMALLINT UNSIGNED, u3 INT UNSIGNED, u4 BIGINT UNSIGNED) VALUES ('2024-01-01 00:00:00', 255, 65535, 4294967295, 18446744073709551615) t16;
SELECT ts, a, b FROM TEXT(ts TIMESTAMP, a INT, b BIGINT) VALUES ('2024-01-01 00:00:00', -2147483648, -9223372036854775808) ('2024-01-02 00:00:00', 0, 0) t17;
SELECT ts, n FROM TEXT(ts TIMESTAMP, n NCHAR(64)) VALUES ('2024-01-01 00:00:00', '中文') ('2024-01-02 00:00:00', 'unicode_test') t18;
SELECT ts, v FROM TEXT(ts TIMESTAMP, v VARCHAR(64)) VALUES ('2024-01-01 00:00:00', '') ('2024-01-02 00:00:00', 'hello world') t19;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 3) ('2024-01-04 00:00:00', 4) t20 WHERE ts >= '2024-01-02 00:00:00' AND ts <= '2024-01-03 00:00:00';
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', NULL) ('2024-01-02 00:00:00', 5) ('2024-01-03 00:00:00', NULL) t21 WHERE a IS NOT NULL;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-03 00:00:00', 30) ('2024-01-04 00:00:00', 40) t22 WHERE a BETWEEN 15 AND 35;
SELECT ts, s FROM TEXT(ts TIMESTAMP, s VARCHAR(32)) VALUES ('2024-01-01 00:00:00', 'apple') ('2024-01-02 00:00:00', 'banana') ('2024-01-03 00:00:00', 'apricot') t23 WHERE s LIKE 'ap%';
SELECT ts, a * 2 AS doubled, a + b AS sum_ab FROM TEXT(ts TIMESTAMP, a INT, b INT) VALUES ('2024-01-01 00:00:00', 3, 4) ('2024-01-02 00:00:00', 5, 6) t24;
SELECT ts, doubled FROM (SELECT ts, a * 2 AS doubled FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 7) ('2024-01-02 00:00:00', 3) inner_t) sub ORDER BY doubled;
SELECT ts, a FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 3) ('2024-01-04 00:00:00', 4) ('2024-01-05 00:00:00', 5) inner_t WHERE a > 1) sub WHERE a < 5;
SELECT ts FROM (SELECT ts, a FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 3) inner_t) mid WHERE a >= 2) outer_t WHERE ts < '2024-01-03 00:00:00';
SELECT ts, v FROM (SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ta UNION ALL SELECT ts, v FROM TEXT(ts TIMESTAMP, v INT) VALUES ('2024-01-03 00:00:00', 3) tb) sub ORDER BY ts;
SELECT score FROM (SELECT ts, a AS score FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 30) ('2024-01-02 00:00:00', 10) ('2024-01-03 00:00:00', 20) src) sub ORDER BY score;
SELECT a FROM (SELECT DISTINCT a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) ('2024-01-03 00:00:00', 1) ('2024-01-04 00:00:00', 3) t_dup) sub ORDER BY a;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-03 00:00:00', 30) ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) t_unsorted;
SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-03 00:00:00', 30) ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) t_unsorted2 ORDER BY ts ASC;
SELECT ts, a FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-03 00:00:00', 3) ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 2) inner_u) sub ORDER BY ts;
SELECT t.ts, t.score, r.label FROM (SELECT ts, score FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) ('2024-01-03 00:00:00', 300) src) t, ref_items r WHERE t.ts = r.ts ORDER BY t.ts;
SELECT r.ts, r.id, t.score FROM ref_items r, (SELECT ts, score FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-03 00:00:00', 30) src) t WHERE r.ts = t.ts ORDER BY r.ts;
SELECT a.ts, a.score, b.label FROM (SELECT ts, score FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) ta) a, (SELECT ts, label FROM TEXT(ts TIMESTAMP, label VARCHAR(16)) VALUES ('2024-01-01 00:00:00', 'x') ('2024-01-02 00:00:00', 'y') tb) b WHERE a.ts = b.ts ORDER BY a.ts;
SELECT t.ts, t.score, r.label FROM (SELECT ts, score FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-03 00:00:00', 300) ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) unsorted_src) t, ref_items r WHERE t.ts = r.ts ORDER BY t.ts;
SELECT ts, score, (SELECT MAX(a) FROM (SELECT ts, a FROM TEXT(ts TIMESTAMP, a INT) VALUES ('2024-01-01 00:00:00', 1) ('2024-01-02 00:00:00', 9) ('2024-01-03 00:00:00', 5) ref_t) sub) AS max_ref FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) outer_t ORDER BY ts;
SELECT ts, s FROM TEXT(ts TIMESTAMP, s BINARY(32)) VALUES ('2024-01-01 00:00:00', 'hello') ('2024-01-02 00:00:00', 'world') t_bin;
SELECT t.ts, t.score, r.label FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) t JOIN ref_items r ON t.ts = r.ts ORDER BY t.ts;
SELECT m.ts, m.id, t.label FROM ref_items m JOIN TEXT(ts TIMESTAMP, label VARCHAR(8)) VALUES ('2024-01-01 00:00:00', 'alpha') ('2024-01-02 00:00:00', 'beta') t ON m.ts = t.ts ORDER BY m.ts;
SELECT m.ts, m.id, t.label FROM ref_items m JOIN TEXT(ts TIMESTAMP, label VARCHAR(8)) VALUES ('2024-01-03 00:00:00', 'gamma') ('2024-01-01 00:00:00', 'alpha') t ON m.ts = t.ts ORDER BY m.ts;
SELECT t.ts, t.score, r.label FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) t INNER JOIN ref_items r ON t.ts=r.ts ORDER BY t.ts;
SELECT r.ts, r.label, t.score FROM ref_items r LEFT JOIN TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) t ON r.ts=t.ts ORDER BY r.ts;
SELECT t.ts, t.score, r.label FROM ref_items r RIGHT JOIN TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) ('2024-01-04 00:00:00', 40) t ON r.ts=t.ts ORDER BY t.ts;
SELECT a.ts, a.score, b.val FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) a JOIN TEXT(ts TIMESTAMP, val INT) VALUES ('2024-01-01 00:00:00', 10) ('2024-01-02 00:00:00', 20) b ON a.ts=b.ts ORDER BY a.ts;
SELECT f.ts, f.val, r.label FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') f JOIN ref_items r ON f.ts=r.ts ORDER BY f.ts;
SELECT r.ts, r.label, f.val FROM ref_items r INNER JOIN FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') f ON r.ts=f.ts ORDER BY r.ts;
SELECT r.ts, r.label, f.val FROM ref_items r LEFT JOIN FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') f ON r.ts=f.ts ORDER BY r.ts;
SELECT f.ts, f.val, r.label FROM ref_items r RIGHT JOIN FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_b.csv', 'ts TIMESTAMP, val INT') f ON r.ts=f.ts ORDER BY f.ts;
SELECT a.ts, a.val, b.val FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') a JOIN FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_b.csv', 'ts TIMESTAMP, val INT') b ON a.ts=b.ts ORDER BY a.ts;
SELECT f.ts, f.val, t.score FROM FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') f JOIN TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) t ON f.ts=t.ts ORDER BY f.ts;
SELECT t.ts, t.score, f.val FROM TEXT(ts TIMESTAMP, score INT) VALUES ('2024-01-01 00:00:00', 100) ('2024-01-02 00:00:00', 200) t JOIN FILE('./cases/09-DataQuerying/08-SubQuery/in/file_source_join_a.csv', 'ts TIMESTAMP, val INT') f ON t.ts=f.ts ORDER BY t.ts;
