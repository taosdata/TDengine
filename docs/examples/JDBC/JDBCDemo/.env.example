# TDengine Security Demo Environment Variables
#
# ⚠️ SECURITY WARNING ⚠️
# 1. Do NOT commit .env file to version control
# 2. Do NOT use default credentials in production
# 3. Keep .env file permissions restrictive (chmod 600 .env)
# 4. Rotate credentials regularly
#
# Copy this file to .env and customize with your environment values

# -------------------------------------------------------------------------
# TDengine Connection Configuration
# -------------------------------------------------------------------------
TDENGINE_HOST=td1.internal.taosdata.com
TDENGINE_PORT=6041
TDENGINE_DB=
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata

# -------------------------------------------------------------------------
# Nacos Configuration (for Token rotation demo)
# -------------------------------------------------------------------------
TDENGINE_NACOS_ADDR=localhost:8848
TDENGINE_NACOS_USER=your_nacos_username
TDENGINE_NACOS_PASSWORD=your_nacos_password

# ⚠️ IMPORTANT: Nacos Default Credentials
# - Nacos default credentials (nacos/nacos) are for LOCAL DEVELOPMENT ONLY
# - In production, you MUST change these credentials
# - Never use default credentials in any deployed environment
# - For local testing, you may use: nacos/nacos (but keep this file private!)
