+  }
+
+  newCode = ctgHandleTaskEnd(pTask, code);
+  if (TSDB_CODE_SUCCESS == code && TSDB_CODE_SUCCESS != newCode) {
+    code = newCode;
+  }
+
+  return code;
+}
