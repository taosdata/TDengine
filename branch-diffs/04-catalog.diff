+static int32_t ctgFinalizeVStbRefDbsTask(SCtgTask* pTask) {
+  int32_t            code = TSDB_CODE_SUCCESS;
+  int32_t            newCode = TSDB_CODE_SUCCESS;
+  SCtgVStbRefDbsCtx* pCtx = (SCtgVStbRefDbsCtx*)pTask->taskCtx;
