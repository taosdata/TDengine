+static SColumnNode* findRefTagOutputColumn(const SVirtualTableScanInfo* pInfo, const SColumnNode* pTargetCol) {
+  if (pInfo == NULL || pInfo->pRefTagCols == NULL || pTargetCol == NULL) {
