+        code != TSDB_CODE_QRY_QUERY_MEM_EXHAUSTED) {
+      if (code != TSDB_CODE_SUCCESS) {
+        qWarn("%s: tagRefSourceScanOneTable failed, pos:%d, code:%s, skipping", __func__, pInfo->curPos,
+               tstrerror(code));
