+
+  pInfo = (STagRefSourceOperatorInfo*)pOperator->info;
+  pTaskInfo = pOperator->pTaskInfo;
+  pAPI = &pTaskInfo->storageAPI;
+  pRes = pInfo->pRes;
+
+  // Check if scan is completed
+  if (pOperator->status == OP_EXEC_DONE) {
+    *ppRes = NULL;
