+    pTagRefSource->pVgroupList->numOfVgroups = numOfVgroups;
+    memcpy(pTagRefSource->pVgroupList->vgroups, pLogicNode->pVgroupList->vgroups, numOfVgroups * sizeof(SVgroupInfo));
